## PROJECT DETAIL PAGE TEMPLATE

Both /espaces/[slug] and /identites/[slug] follow this exact pattern:

```typescript
// src/app/espaces/[slug]/page.tsx
import { notFound } from 'next/navigation';
import { getProjectBySlug, getAllProjectSlugs, getAllProjects } from '@/lib/content';
import ProjectDetail from '@/components/ProjectDetail/ProjectDetail';
import ProjectCarousel from '@/components/ProjectCarousel/ProjectCarousel';

export async function generateStaticParams() {
  return getAllProjectSlugs('espaces');
}

export default async function EspaceDetailPage({
  params,
}: {
  params: { slug: string };
}) {
  const project = getProjectBySlug('espaces', params.slug);
  if (!project) notFound();

  const allProjects = getAllProjects();
  const carouselProjects = allProjects.filter((p) => p.slug !== project.slug);

  return (
    <>
      <ProjectDetail project={project} />
      <ProjectCarousel projects={carouselProjects} />
    </>
  );
}
```

